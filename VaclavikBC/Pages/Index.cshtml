	@* <script>
        let eventsByDate = {};
        let currentWeekStart = null;

        function formatDateDDMMYYYY(date) {
            const d = new Date(date);
            return `${d.getDate().toString().padStart(2,'0')}.${(d.getMonth()+1).toString().padStart(2,'0')}.${d.getFullYear()}`;
        }
        function formatYMD(date) {
            const d = new Date(date);
            return `${d.getFullYear()}-${(d.getMonth()+1).toString().padStart(2,'0')}-${d.getDate().toString().padStart(2,'0')}`;
        }
        function getMondayOfWeek(date) {
            const d = new Date(date);
            d.setHours(0,0,0,0);
            const day = d.getDay();
            const diff = (day === 0 ? 6 : day - 1);
            d.setDate(d.getDate() - diff);
            return d;
        }
        function getWeekDates(mondayDate) {
            const dates = [];
            for (let i = 0; i < 7; i++) {
                const d = new Date(mondayDate);
                d.setDate(mondayDate.getDate() + i);
                dates.push(d);
            }
            return dates;
        }
        function updateWeekInfoDisplay(weekStart) {
            const weekDates = getWeekDates(weekStart);
            const range = `${formatDateDDMMYYYY(weekDates[0])} – ${formatDateDDMMYYYY(weekDates[6])}`;
            const span = document.getElementById('weekRangeText');
            if (span) span.innerText = range;
        }
        function minutesToTime(minutes) {
            const h = Math.floor(minutes / 60);
            const m = minutes % 60;
            return `${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}`;
        }
        function timeToMinutes(timeStr) {
            const [h,m] = timeStr.split(':').map(Number);
            return h * 60 + m;
        }
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]));
        }
        function deleteEventById(dateKey, eventId) {
            if (!eventsByDate[dateKey]) return;
            eventsByDate[dateKey] = eventsByDate[dateKey].filter(ev => ev.id !== eventId);
            if (eventsByDate[dateKey].length === 0) delete eventsByDate[dateKey];
            renderCalendar();
        }

        // ---- DYNAMIC EVENT HEIGHTS (unchanged) ----
        function getMaxOverlapForEvent(events, idx) {
            const ev = events[idx];
            let maxCount = 1;
            for (let t = ev.startMin; t < ev.endMin; t++) {
                let count = 0;
                for (let j = 0; j < events.length; j++) {
                    if (events[j].startMin <= t && t < events[j].endMin) count++;
                }
                if (count > maxCount) maxCount = count;
            }
            return maxCount;
        }

        function populateEventsForRow(rowElement, dateKey) {
            const eventsContainer = rowElement.querySelector('.row-events');
            if (!eventsContainer) return;
            eventsContainer.innerHTML = '';
            let eventsList = eventsByDate[dateKey] || [];
            if (eventsList.length === 0) {
                rowElement.style.height = '';
                rowElement.style.minHeight = '';
                return;
            }

            let globalMax = 0;
            for (let i = 0; i < eventsList.length; i++) {
                const ov = getMaxOverlapForEvent(eventsList, i);
                if (ov > globalMax) globalMax = ov;
            }
            const rowHeight = Math.max(85, globalMax * 28);
            rowElement.style.height = `${rowHeight}px`;
            rowElement.style.minHeight = `${rowHeight}px`;

            const eventsWithHeight = eventsList.map((ev, idx) => {
                const overlap = getMaxOverlapForEvent(eventsList, idx);
                const heightPercent = (1 / overlap) * 100;
                return { ...ev, heightPercent, overlap };
            });

            const placed = [];
            eventsWithHeight.sort((a,b) => a.startMin - b.startMin);

            for (const ev of eventsWithHeight) {
                let bestTop = 0;
                let placedOk = false;
                for (let tryTop = 0; tryTop <= 100 - ev.heightPercent; tryTop++) {
                    let conflict = false;
                    for (const p of placed) {
                        if (ev.startMin < p.endMin && p.startMin < ev.endMin) {
                            if (tryTop < p.topPercent + p.heightPercent && tryTop + ev.heightPercent > p.topPercent) {
                                conflict = true;
                                break;
                            }
                        }
                    }
                    if (!conflict) {
                        bestTop = tryTop;
                        placedOk = true;
                        break;
                    }
                }
                if (!placedOk) bestTop = 100 - ev.heightPercent;
                placed.push({
                    topPercent: bestTop,
                    heightPercent: ev.heightPercent,
                    startMin: ev.startMin,
                    endMin: ev.endMin,
                    event: ev
                });
            }

            const totalMinutes = 24 * 60;
            for (const p of placed) {
                const ev = p.event;
                const leftPercent = (ev.startMin / totalMinutes) * 100;
                const widthPercent = ((ev.endMin - ev.startMin) / totalMinutes) * 100;
                const eventDiv = document.createElement('div');
                eventDiv.className = 'event';
                eventDiv.style.left = `${leftPercent}%`;
                eventDiv.style.width = `${widthPercent}%`;
                eventDiv.style.top = `${p.topPercent}%`;
                eventDiv.style.height = `${p.heightPercent}%`;
                eventDiv.style.minHeight = '20px';

                const tooltipText = `${escapeHtml(ev.title)} | ${minutesToTime(ev.startMin)} – ${minutesToTime(ev.endMin)}`;
                eventDiv.setAttribute('title', tooltipText);

                eventDiv.innerHTML = `
                    <strong>${escapeHtml(ev.title)}</strong>
                    <span class="remove" data-event-id="${ev.id}" data-date-key="${dateKey}">&times;</span>
                `;
                const removeSpan = eventDiv.querySelector('.remove');
                if (removeSpan) {
                    removeSpan.addEventListener('click', (e) => {
                        e.stopPropagation();
                        deleteEventById(removeSpan.getAttribute('data-date-key'), removeSpan.getAttribute('data-event-id'));
                    });
                }
                eventsContainer.appendChild(eventDiv);
            }
        }

        function renderCalendar() {
            const calendarGrid = document.getElementById('calendarGrid');
            if (!calendarGrid) return;
            calendarGrid.innerHTML = '';
            // Header
            const headerRow = document.createElement('div');
            headerRow.className = 'calendar-header';
            const emptyCorner = document.createElement('div');
            emptyCorner.className = 'header-cell';
            emptyCorner.innerText = '';
            headerRow.appendChild(emptyCorner);
            for (let hour = 0; hour < 24; hour++) {
                const hourCell = document.createElement('div');
                hourCell.className = 'header-cell';
                hourCell.innerText = `${hour.toString().padStart(2,'0')}:00`;
                headerRow.appendChild(hourCell);
            }
            calendarGrid.appendChild(headerRow);
            // Day rows
            const weekDates = getWeekDates(currentWeekStart);
            const weekdayNames = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"];
            for (let i = 0; i < 7; i++) {
                const currentDate = weekDates[i];
                const dateKey = formatYMD(currentDate);
                const rowDiv = document.createElement('div');
                rowDiv.className = 'calendar-row';
                rowDiv.setAttribute('data-date', dateKey);
                const dayLabel = document.createElement('div');
                dayLabel.className = 'day-label';
                dayLabel.innerHTML = `<div class="day-name">${weekdayNames[i]}</div><div class="day-date">${formatDateDDMMYYYY(currentDate)}</div>`;
                rowDiv.appendChild(dayLabel);
                for (let hour = 0; hour < 24; hour++) {
                    const hourCell = document.createElement('div');
                    hourCell.className = 'hour-cell';
                    hourCell.setAttribute('data-hour', hour);
                    rowDiv.appendChild(hourCell);
                }
                const eventsContainer = document.createElement('div');
                eventsContainer.className = 'row-events';
                eventsContainer.id = `eventsRow_${dateKey}`;
                rowDiv.appendChild(eventsContainer);
                calendarGrid.appendChild(rowDiv);
            }
            const allRows = document.querySelectorAll('.calendar-row');
            for (let row of allRows) {
                const dateAttr = row.getAttribute('data-date');
                if (dateAttr) populateEventsForRow(row, dateAttr);
            }
        }

        function addEventFromUI() {
            const daySelect = document.getElementById('daySelect');
            const selectedDayIndex = parseInt(daySelect.value, 10);
            const weekDates = getWeekDates(currentWeekStart);
            if (selectedDayIndex < 0 || selectedDayIndex >= weekDates.length) return;
            const targetDate = weekDates[selectedDayIndex];
            const dateKey = formatYMD(targetDate);
            const startTimeStr = document.getElementById('startTime').value;
            const endTimeStr = document.getElementById('endTime').value;
            let title = document.getElementById('eventTitle').value.trim();
            if (!title) title = 'Event';
            if (!startTimeStr || !endTimeStr) { alert('Enter start and end time'); return; }
            const startMin = timeToMinutes(startTimeStr);
            let endMin = timeToMinutes(endTimeStr);
            if (endMin <= startMin) { alert('End after start'); return; }
            if (startMin < 0 || endMin > 1440) { alert('Times 00:00–24:00'); return; }
            const eventId = Date.now() + '-' + Math.random().toString(36).substring(2, 6);
            const newEvent = { id: eventId, startMin, endMin, title };
            if (!eventsByDate[dateKey]) eventsByDate[dateKey] = [];
            eventsByDate[dateKey].push(newEvent);
            renderCalendar();
        }

        function navigateWeek(delta) {
            const newMonday = new Date(currentWeekStart);
            newMonday.setDate(currentWeekStart.getDate() + delta * 7);
            currentWeekStart = newMonday;
            updateWeekInfoDisplay(currentWeekStart);
            renderCalendar();
        }

        function getWeekNumber(date) {
            const d = new Date(date);
            d.setHours(0,0,0);
            d.setDate(d.getDate() + 3 - (d.getDay() + 6) % 7);
            const week1 = new Date(d.getFullYear(), 0, 4);
            return 1 + Math.round(((d - week1) / 86400000 - 3 + (week1.getDay() + 6) % 7) / 7);
        }

        function openWeekPicker() {
            const tempInput = document.createElement('input');
            tempInput.type = 'week';
            tempInput.style.position = 'fixed';
            tempInput.style.left = '42%';
            tempInput.style.top = '25%';
            tempInput.style.opacity = '0';
            tempInput.style.pointerEvents = 'auto';
            tempInput.style.zIndex = '10000';
            tempInput.style.background = 'transparent';
            tempInput.style.border = 'none';

            const year = currentWeekStart.getFullYear();
            const week = getWeekNumber(currentWeekStart);
            tempInput.value = `${year}-W${week.toString().padStart(2,'0')}`;

            document.body.appendChild(tempInput);

            tempInput.focus();
            if (tempInput.showPicker) {
                tempInput.showPicker();
            } else {
                tempInput.click();
            }

            const onChange = (e) => {
                const val = tempInput.value;
                if (val) {
                    const match = val.match(/^(\d{4})-W(\d{1,2})$/);
                    if (match) {
                        const year = parseInt(match[1],10);
                        const week = parseInt(match[2],10);
                        const janFirst = new Date(year, 0, 1);
                        const firstMonday = getMondayOfWeek(janFirst);
                        const mondayDate = new Date(firstMonday);
                        mondayDate.setDate(firstMonday.getDate() + (week-1)*7);
                        currentWeekStart = getMondayOfWeek(mondayDate);
                        updateWeekInfoDisplay(currentWeekStart);
                        renderCalendar();
                    }
                }

                tempInput.removeEventListener('change', onChange);
                tempInput.removeEventListener('blur', onBlur);
                document.body.removeChild(tempInput);
            };

            const onBlur = () => {
                tempInput.removeEventListener('change', onChange);
                tempInput.removeEventListener('blur', onBlur);
                if (document.body.contains(tempInput)) document.body.removeChild(tempInput);
            };

            tempInput.addEventListener('change', onChange);
            tempInput.addEventListener('blur', onBlur);
        }

        function addSampleEventsIfEmpty() {
            const weekDates = getWeekDates(currentWeekStart);
            let hasAny = false;
            for (let d of weekDates) {
                if (eventsByDate[formatYMD(d)]?.length) { hasAny = true; break; }
            }
            if (!hasAny) {
                const demoKey = formatYMD(weekDates[3]); // Thursday
                eventsByDate[demoKey] = [
                    { id: 'e1', startMin: 9*60, endMin: 12*60, title: 'Event1' },
                    { id: 'e2', startMin: 9*60, endMin: 10*60, title: 'Event2' },
                    { id: 'e3', startMin: 9*60+30, endMin: 10*60, title: 'Event3' },
                    { id: 'e4', startMin: 11*60, endMin: 12*60, title: 'Event4' }
                ];
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const today = new Date();
            today.setHours(0,0,0);
            currentWeekStart = getMondayOfWeek(today);
            addSampleEventsIfEmpty();
            updateWeekInfoDisplay(currentWeekStart);
            renderCalendar();

            document.getElementById('prevWeekBtn')?.addEventListener('click', () => navigateWeek(-1));
            document.getElementById('nextWeekBtn')?.addEventListener('click', () => navigateWeek(1));
            document.getElementById('weekInfoTrigger')?.addEventListener('click', openWeekPicker);
            document.getElementById('addEventBtn')?.addEventListener('click', (e) => { e.preventDefault(); addEventFromUI(); });
            document.getElementById('eventTitle')?.addEventListener('keypress', (e) => { if(e.key === 'Enter') addEventFromUI(); });
        });
    </script> *@

