@* <script>
    // Helper to get stored events from localStorage
    function getStoredEvents() {
        return JSON.parse(localStorage.getItem('aggregatedEvents') || '[]');
    }

    function updateEventDisplay() {
        const events = getStoredEvents();
        document.getElementById('event-count').innerText = events.length;
        document.getElementById('events-json').innerText = JSON.stringify(events, null, 2);
    }

    // OAuth Popup Handling
    function oauthPopup(provider) {
        // Determine the challenge URL
        let url;
        if (provider === 'google') {
            url = /* '/Identity/Account/ExternalLogin?provider=Google&returnUrl=/'; */ '/Account/OAuthLogin?provider=Google';
        } else if (provider === 'microsoft') {
            url = /* '/Identity/Account/ExternalLogin?provider=Microsoft&returnUrl=/'; */ '/Account/OAuthLogin?provider=Microsoft';
        } else if (provider === 'calendly') {
            url = /* '/challenge/calendly'; */ '/Account/OAuthLogin?provider=Calendly';
        }

        // Open popup window (width, height)
        const width = 600, height = 700;
        const left = (screen.width - width) / 2;
        const top = (screen.height - height) / 2;
        const popup = window.open(url, "oauthPopup",
            `width=${width},height=${height},left=${left},top=${top},resizable=yes,scrollbars=yes`);

        // Poll for popup close to refresh connection status
        const timer = setInterval(() => {
            if (popup.closed) {
                clearInterval(timer);
                // Optionally refresh connection status by calling an API endpoint
                fetchConnectionStatus();
            }
        }, 500);
    }

    // Fetch connection status from server
    async function fetchConnectionStatus() {
        const response = await fetch('/api/connection-status');
        const status = await response.json();
        document.getElementById('google-status').innerHTML = status.google ? '✅' : '❌';
        document.getElementById('microsoft-status').innerHTML = status.microsoft ? '✅' : '❌';
        document.getElementById('calendly-status').innerHTML = status.calendly ? '✅' : '❌';

        // If any provider connected, load calendars
        if (status.google || status.microsoft || status.calendly) {
            loadCalendars();
        }
    }

    // Load available calendars from connected providers
    async function loadCalendars() {
        const response = await fetch('/api/calendars');
        const calendars = await response.json();
        const container = document.getElementById('calendars-container');
        container.innerHTML = '';
        calendars.forEach(cal => {
            const div = document.createElement('div');
            div.className = 'calendar-item';
            div.innerHTML = `<input type="checkbox" value="${cal.id}" data-provider="${cal.provider}"> ${cal.name} (${cal.provider})`;
            container.appendChild(div);
        });
        document.getElementById('calendar-list').style.display = 'block';
    }

    // Fetch events from selected calendars
    async function fetchEvents() {
        const checkboxes = document.querySelectorAll('#calendars-container input:checked');
        const selected = Array.from(checkboxes).map(cb => ({
            id: cb.value,
            provider: cb.dataset.provider
        }));

        // Group by provider (or just send as list)
        const response = await fetch('/api/events', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ selectedCalendars: selected })
        });
        const events = await response.json();
        // Temporarily store in memory for later local storage
        window.lastFetchedEvents = events;
        document.getElementById('store-locally-btn').disabled = false;
        alert(`Fetched ${events.length} events. Click "Store Locally" to save.`);
    }

    // Store fetched events in localStorage
    function storeLocally() {
        if (!window.lastFetchedEvents) return;
        localStorage.setItem('aggregatedEvents', JSON.stringify(window.lastFetchedEvents));
        updateEventDisplay();
        document.getElementById('store-locally-btn').disabled = true;
    }

    // Export to .ics file
    async function exportICS() {
        // We can either generate on server using stored events from localStorage or send events to server.
        // For simplicity, we'll send stored events to server to generate .ics.
        const events = getStoredEvents();
        if (events.length === 0) {
            alert('No events stored locally.');
            return;
        }
        const response = await fetch('/api/export', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(events)
        });
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'calendars.ics';
        a.click();
        window.URL.revokeObjectURL(url);
    }

    // Discard local data
    function discardLocal() {
        localStorage.removeItem('aggregatedEvents');
        updateEventDisplay();
    }

    // Initial load
    window.onload = () => {
        fetchConnectionStatus();
        updateEventDisplay();
    };
</script> *@

